<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jornalista Perdido — Editor de Vídeo</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Barlow+Condensed:wght@300;400;600;700&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:   #1a2d40;
      --blue:   #1a4d8c;
      --cream:  #f5f0e8;
      --paper:  #faf7f2;
      --ink:    #1e1e1e;
      --muted:  #7a7060;
      --border: #d4cbbа;
      --serif:  'Playfair Display', Georgia, serif;
      --cond:   'Barlow Condensed', sans-serif;
      --body:   'Lora', Georgia, serif;
    }

    html { scroll-behavior: smooth; }
    body { background: var(--paper); color: var(--ink); font-family: var(--body); overflow-x: hidden; }

    /* ── HEADER ── */
    header {
      background: var(--paper);
      border-bottom: 2px solid var(--navy);
      position: sticky; top: 0; z-index: 100;
    }
    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }
    .masthead {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 0;
    }
    .masthead img { height: 44px; }
    .logo-jornalista {
      display: block;
      font-family: var(--serif);
      font-size: 1.6rem;
      font-weight: 400;
      color: var(--navy);
      line-height: 1;
    }
    .logo-perdido {
      display: block;
      font-family: var(--cond);
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: .1em;
      color: var(--navy);
      line-height: 1;
    }
    .logo-dot { color: var(--blue); }

    nav ul { display: flex; list-style: none; }
    nav a {
      display: block;
      padding: .5rem 1.4rem;
      font-family: var(--cond);
      font-size: .78rem;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color .2s;
      border-left: 1px solid #e0d9ce;
    }
    nav a:hover { color: var(--navy); }

    /* ── HERO ── */
    #hero {
      max-width: 1100px;
      margin: 0 auto;
      padding: 5rem 3rem;
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 5rem;
      align-items: center;
    }
    .hero-kicker {
      font-family: var(--cond);
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 1.2rem;
    }
    .hero-hed {
      font-family: var(--serif);
      font-size: clamp(2.2rem, 4vw, 3.6rem);
      font-weight: 400;
      color: var(--navy);
      line-height: 1.2;
      margin-bottom: 1.4rem;
    }
    .hero-hed em { font-style: italic; }
    .hero-dek {
      font-size: .95rem;
      color: var(--muted);
      line-height: 1.9;
      margin-bottom: 2.5rem;
    }
    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn-primary {
      padding: .75rem 1.8rem;
      background: var(--navy);
      color: #fff;
      font-family: var(--cond);
      font-size: .76rem;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      text-decoration: none;
      border: 2px solid var(--navy);
      transition: all .25s;
    }
    .btn-primary:hover { background: transparent; color: var(--navy); }
    .btn-outline {
      padding: .75rem 1.8rem;
      background: transparent;
      color: var(--navy);
      font-family: var(--cond);
      font-size: .76rem;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      text-decoration: none;
      border: 2px solid #c8bfaa;
      transition: all .25s;
    }
    .btn-outline:hover { border-color: var(--navy); }

    /* 16:9 video */
    .hero-video {
      position: relative;
      padding-bottom: 56.25%;
      background: var(--navy);
      border: 1px solid #d4cbbа;
    }
    .hero-video iframe {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      border: none;
    }

    /* ── DIVIDER ── */
    .divider {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 3rem;
      border-top: 1px solid #ddd5c5;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .divider-label {
      font-family: var(--cond);
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: #bbb0a0;
      white-space: nowrap;
      padding: .6rem 0;
    }

    /* ── SOBRE ── */
    #sobre {
      max-width: 1100px;
      margin: 0 auto;
      padding: 5rem 3rem;
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 5rem;
      align-items: start;
    }
    .section-label {
      font-family: var(--cond);
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: .8rem;
    }
    .section-h2 {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      font-weight: 400;
      color: var(--navy);
      margin-bottom: 2rem;
      line-height: 1.2;
    }
    .sobre-p {
      font-size: .95rem;
      color: #555;
      line-height: 1.9;
      margin-bottom: 1.1rem;
    }
    .sobre-p strong { color: var(--navy); font-weight: 600; }

    .skills-table { width: 100%; border-collapse: collapse; margin-top: .5rem; }
    .skills-table tr { border-bottom: 1px solid #e0d9ce; }
    .skills-table tr:first-child { border-top: 2px solid var(--navy); }
    .skills-table td {
      padding: .65rem 0;
      font-family: var(--cond);
      font-size: .82rem;
      color: var(--navy);
      font-weight: 600;
    }
    .skills-table td:last-child {
      text-align: right;
      color: var(--muted);
      font-weight: 400;
    }

    /* sidebar timeline */
    .sidebar-title {
      font-family: var(--cond);
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--muted);
      border-bottom: 2px solid var(--navy);
      padding-bottom: .5rem;
      margin-bottom: 1.5rem;
    }
    .tl-item {
      padding-bottom: 1.5rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid #e0d9ce;
    }
    .tl-item:last-child { border-bottom: none; padding-bottom: 0; margin-bottom: 0; }
    .tl-year {
      font-family: var(--cond);
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: .1em;
      color: var(--blue);
      margin-bottom: .3rem;
    }
    .tl-title {
      font-family: var(--serif);
      font-size: 1rem;
      color: var(--navy);
      margin-bottom: .3rem;
    }
    .tl-desc {
      font-size: .8rem;
      color: var(--muted);
      line-height: 1.6;
      font-family: var(--cond);
    }

    /* ── PORTFOLIO ── */
    #portfolio {
      background: var(--navy);
      padding: 5rem 0;
    }
    .portfolio-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 3rem;
    }
    #portfolio .section-label { color: #7aabdb; }
    #portfolio .section-h2 { color: #fff; }
    .video-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
      gap: 1.5rem;
      margin-top: 3rem;
    }
    .vcard {
      background: #12202e;
      border: 1px solid rgba(255,255,255,.06);
      transition: border-color .25s;
    }
    .vcard:hover { border-color: rgba(255,255,255,.2); }
    .video-embed { position: relative; padding-bottom: 56.25%; background: #000; }
    .video-embed iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; }
    .vcard-body { padding: 1.2rem; border-top: 2px solid var(--blue); }
    .vcard-cat {
      font-family: var(--cond);
      font-size: .6rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: #7aabdb;
      margin-bottom: .4rem;
    }
    .vcard-title {
      font-family: var(--serif);
      font-size: 1.05rem;
      color: #fff;
      margin-bottom: .4rem;
      line-height: 1.3;
    }
    .vcard-desc {
      font-size: .78rem;
      color: rgba(255,255,255,.4);
      font-family: var(--cond);
      line-height: 1.6;
    }

    /* ── CONTATO ── */
    #contato {
      max-width: 1100px;
      margin: 0 auto;
      padding: 5rem 3rem;
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 5rem;
      align-items: start;
    }
    .contato-quote {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-style: italic;
      color: var(--navy);
      border-left: 3px solid var(--blue);
      padding-left: 1.2rem;
      margin-bottom: 2rem;
      line-height: 1.6;
    }
    .contato-desc {
      font-size: .9rem;
      color: var(--muted);
      line-height: 1.9;
      margin-bottom: 2rem;
    }
    .contact-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: .7rem 0;
      border-bottom: 1px solid #e0d9ce;
      font-family: var(--cond);
      font-size: .82rem;
    }
    .cr-label { font-weight: 700; color: var(--navy); letter-spacing: .06em; }
    .cr-val { color: var(--muted); }
    .cr-val a { color: var(--blue); text-decoration: none; }
    .cr-val a:hover { text-decoration: underline; }

    /* form */
    form { display: flex; flex-direction: column; gap: 1rem; }
    label {
      display: block;
      font-family: var(--cond);
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--navy);
      margin-bottom: .3rem;
    }
    input, textarea, select {
      width: 100%;
      background: #fff;
      border: 1px solid #d4cbbа;
      border-bottom: 2px solid var(--navy);
      color: var(--ink);
      padding: .7rem .8rem;
      font-family: var(--body);
      font-size: .88rem;
      outline: none;
      transition: border-bottom-color .2s;
      -webkit-appearance: none;
    }
    input:focus, textarea:focus, select:focus { border-bottom-color: var(--blue); }
    textarea { min-height: 120px; resize: vertical; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .btn-enviar {
      align-self: flex-start;
      padding: .8rem 2rem;
      background: var(--navy);
      color: #fff;
      border: 2px solid var(--navy);
      font-family: var(--cond);
      font-size: .76rem;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all .25s;
    }
    .btn-enviar:hover { background: transparent; color: var(--navy); }
    .form-ok {
      display: none;
      background: #eef6ee;
      border-left: 3px solid #2a7a2a;
      padding: .8rem 1rem;
      font-family: var(--cond);
      font-size: .82rem;
      color: #2a7a2a;
      font-weight: 600;
    }

    /* ── FOOTER ── */
    footer {
      background: var(--navy);
      padding: 2.5rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1.5rem;
    }
    .footer-logo { display: flex; align-items: center; gap: .8rem; }
    .footer-logo img { height: 32px; opacity: .6; }
    .fl-j { font-family: var(--serif); font-size: 1.1rem; color: #fff; display: block; line-height: 1; }
    .fl-p { font-family: var(--cond); font-size: .9rem; font-weight: 600; letter-spacing: .1em; color: rgba(255,255,255,.45); display: block; line-height: 1; }
    .footer-links { display: flex; gap: 2rem; }
    .footer-links a {
      font-family: var(--cond);
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: rgba(255,255,255,.4);
      text-decoration: none;
      transition: color .2s;
    }
    .footer-links a:hover { color: #fff; }
    .footer-copy {
      font-family: var(--cond);
      font-size: .65rem;
      color: rgba(255,255,255,.25);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 860px) {
      .header-inner { padding: 0 1.2rem; }
      nav { display: none; }
      #hero, #sobre, #contato { grid-template-columns: 1fr; gap: 2.5rem; padding: 3rem 1.2rem; }
      .portfolio-inner { padding: 0 1.2rem; }
      footer { padding: 2rem 1.2rem; }
      .form-row { grid-template-columns: 1fr; }
      .footer-links { display: none; }
    }
  </style>
</head>
