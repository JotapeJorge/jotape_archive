        <div class="tl-title">Mergulho no Audiovisual</div>
        <div class="tl-desc">Primeiros projetos de edição unindo narrativa jornalística e linguagem visual.</div>
      </div>
      <div class="tl-item">
        <div class="tl-year">20XX</div>
        <div class="tl-title">Canal Jornalista Perdido</div>
        <div class="tl-desc">Lançamento do canal no YouTube com conteúdo de [tema].</div>
      </div>
      <div class="tl-item">
        <div class="tl-year">Hoje</div>
        <div class="tl-title">Editor Freelance</div>
        <div class="tl-desc">Canal ativo + projetos freelance. Disponível para novos clientes.</div>
      </div>
    </div>
  </section>

  <div class="divider"><span class="divider-label">Portfólio</span></div>

  <!-- PORTFOLIO -->
  <section id="portfolio">
    <div class="portfolio-inner">
      <p class="section-label">Trabalhos selecionados</p>
      <h2 class="section-h2">Portfólio</h2>
      <div class="video-grid">

        <!-- Troque os IDs pelos seus vídeos -->
        <div class="vcard">
